generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  playlists Playlist[]
  articles  Article[]
  createdAt DateTime   @default(now())
}

model Article {
  id         String    @id @default(uuid())
  userId     String
  title      String?
  sourceUrl  String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
}

model Playlist {
  id        String         @id @default(uuid())
  userId    String
  name      String
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  audioJobId String
  position   Int
  title      String?
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position])
}
