# Shared defaults
NODE_ENV=development

# Backend
BACKEND_PORT=4000
BACKEND_JWT_SECRET=change-me
BACKEND_GOOGLE_CLIENT_ID=change-me
BACKEND_GOOGLE_CLIENT_SECRET=change-me
BACKEND_GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
BACKEND_PLAYLIST_SERVICE_URL=http://playlist-service:4001
BACKEND_AUDIO_SERVICE_HOST=audio-service
BACKEND_AUDIO_SERVICE_PORT=50051

# Frontend
VITE_API_URL=http://localhost:4000

# Playlist service
PLAYLIST_SERVICE_PORT=4001
DATABASE_URL=postgresql://sonora:sonora@postgres:5432/sonora?schema=public

# Audio service
AUDIO_SERVICE_PORT=50051
MONGODB_URI=mongodb://mongo:27017/sonora
TTS_PROVIDER=edge-tts
AUDIO_STORAGE_DIR=/tmp/sonora-audio
